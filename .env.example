# Basic-auth gate for the whole dashboard (username can be anything, only pass is checked)
DASHBOARD_PASSWORD=change-me

# Supabase — used by /customer-success (Zoho Desk ticket analytics)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Zoho Desk — used by /customer-success (support tickets) and /onboarding
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=

# /onboarding — Zoho Desk views
ZOHO_VIEW_ID=
ZOHO_CLOSED_VIEW_ID=

# /ptos — reads from a Google Sheet. The sheet must be shared as
# "Anyone with the link — Viewer" for the public CSV export to work.
# If you switch to a private sheet later, swap lib/sheets.js for
# a service-account-auth implementation.
