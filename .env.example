# Basic-auth gate for the whole dashboard (user blank, pass = this).
# Leave empty to disable the gate.
DASHBOARD_PASSWORD=change-me

# ---------- /customer-success ----------
# Supabase (ticket cache)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Daily Zoho → Supabase sync
CRON_SECRET=

# CS uses its own Zoho app — namespaced ZOHO_DESK_*
ZOHO_DESK_CLIENT_ID=
ZOHO_DESK_CLIENT_SECRET=
ZOHO_DESK_REFRESH_TOKEN=
ZOHO_DESK_ORG_ID=

# ---------- /onboarding ----------
# Uses a different Zoho app than /customer-success
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
# Get this by opening the target view in Zoho Desk — the URL contains the ID
ZOHO_VIEW_ID=
# Optional — the "Closed Onboarding tickets" section will error-out without it
ZOHO_CLOSED_VIEW_ID=

# ---------- Shared Zoho API endpoints (defaults are fine) ----------
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_DESK_API_DOMAIN=https://desk.zoho.com/api/v1

# ---------- /ptos ----------
# No env vars needed — reads a public Google Sheet via CSV export.
# The sheet must be shared as "Anyone with the link — Viewer".
